# Motore: live (Sisal reale) oppure stub (fake per UI)
ENGINE_MODE=live
CATALOG_MODE=Solo prossimi giorni (veloce)
SISAL_MAX_WORKERS=6
QUOTE_CACHE_TTL_SECONDS=120

# Supabase (opzionale in locale: senza queste usa crediti in memoria)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://example.com/success
STRIPE_CANCEL_URL=https://example.com/cancel
# Opzionali: price id creati in Stripe Dashboard
STRIPE_PRICE_1=
STRIPE_PRICE_5=
STRIPE_PRICE_10=
STRIPE_PRICE_15=

# 1 = consente POST /dev/add-credits (in produzione su Render: 0)
ALLOW_DEV_CREDIT_TOPUP=1

# Su Render Free imposta anche:
# ALLOW_DEV_CREDIT_TOPUP=0
# e le chiavi SUPABASE_* dal tuo progetto (mai committare .env)
