# Motore: live (Sisal reale) oppure stub (fake per UI)
ENGINE_MODE=live
# Tutte le partite (più lento) | Solo prossimi giorni (veloce)
CATALOG_MODE=Tutte le partite (più lento)
# 0 = calcolo base (veloce); 1 = mercati estesi eventDetail
SISAL_INCLUDE_EXTENDED=0
SISAL_MAX_WORKERS=6
QUOTE_CACHE_TTL_SECONDS=120
# Proxy di uscita italiano per Sisal (opzionale)
# Esempio: http://user:pass@host:port   oppure   socks5://user:pass@host:port
SISAL_HTTP_PROXY=

# Gateway IT sul PC di casa (consigliato, gratis): avvia start_gateway_it.bat
# e metti su Render l'URL del tunnel Cloudflare + lo stesso secret di .worker_secret
SISAL_WORKER_URL=
SISAL_WORKER_SECRET=

# Supabase (opzionale in locale: senza queste usa crediti in memoria)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://example.com/success
STRIPE_CANCEL_URL=https://example.com/cancel
# Opzionali: price id creati in Stripe Dashboard
STRIPE_PRICE_1=
STRIPE_PRICE_5=
STRIPE_PRICE_10=
STRIPE_PRICE_15=

# 1 = consente POST /dev/add-credits (in produzione su Render: 0)
ALLOW_DEV_CREDIT_TOPUP=1

# Su Render Free imposta anche:
# ALLOW_DEV_CREDIT_TOPUP=0
# e le chiavi SUPABASE_* dal tuo progetto (mai committare .env)
